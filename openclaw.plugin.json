{
  "id": "openclaw-rp-plugin",
  "name": "OpenClaw RP Plugin",
  "description": "SillyTavern-compatible role-play command plugin for OpenClaw.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentImage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "provider": {
            "type": "string",
            "enum": ["inherit", "openai", "gemini"],
            "default": "inherit"
          },
          "imageModel": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
